# Phase 2 — Supabase (NE PAS remplir en Phase 1 : le site est front-only)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# WhatsApp business de l'opérateur, format international SANS "+" (ex: 66XXXXXXXXX).
# En Phase 1, le numéro vit dans config/client.ts ; cette var sert pour la Phase 2.
NEXT_PUBLIC_WHATSAPP_NUMBER=66XXXXXXXXX

# Phase 2 — Cloudflare Turnstile (anti-spam). Vide en Phase 1.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
